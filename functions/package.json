{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "main": "index.js",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "migrate:schema:dry": "node scripts/migrate-firestore-schema.js --appId=haulix-tms",
    "migrate:schema": "node scripts/migrate-firestore-schema.js --appId=haulix-tms --execute"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.9.0",
    "nodemailer": "^6.10.1",
    "resend": "^6.12.3"
  }
}
